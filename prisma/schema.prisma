// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  SUPERVISOR
  COACH
  AGENT
}

enum LeadStatus {
  newLead
  leadWithData
  pendingSS
  pendingAnalysis
  pendingAccount
  pendingPayments
  suspended
}

enum TypeCustomer {
  lead
  customer
}

// ─── EMPRESA ─────────────────────────────────────────────────────────────────

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  teams Team[]
  leads Lead[]
}

// ─── EQUIPO ──────────────────────────────────────────────────────────────────

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  companyId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])
  users     User[]
  leads     Lead[]
}

// ─── USUARIO ─────────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  name      String
  email     String?  @unique
  password  String
  role      Role
  active    Boolean  @default(true)
  companyId Int?
  teamId    Int?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company           Company?   @relation(fields: [companyId], references: [id])
  team              Team?      @relation(fields: [teamId], references: [id])
  leads             Lead[]
  notes             Note[]
  remindersAssigned Reminder[] @relation("ReminderAssignedTo")
  remindersCreated  Reminder[] @relation("ReminderCreatedBy")
}

// ─── PERMISOS ─────────────────────────────────────────────────────────────────

enum PermissionScope {
  ALL // Admin - ve todo
  COMPANY // Supervisor - ve su empresa
  TEAM // Coach - ve su equipo
  OWN // Agent - ve solo lo suyo
  NONE // Sin acceso
}

model Permission {
  id        Int             @id @default(autoincrement())
  role      Role
  module    String // "leads", "users", "companies", "teams"
  canCreate Boolean         @default(false)
  canRead   PermissionScope @default(NONE)
  canUpdate PermissionScope @default(NONE)
  canDelete Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([role, module]) // Un permiso por rol/módulo
}

// ─── LEAD (CLIENTE) ──────────────────────────────────────────────────────────

model Lead {
  id           Int          @id @default(autoincrement())
  firstName    String
  lastName     String?
  phone1       String       @unique
  phone2       String?
  ssn          String?      @unique
  address      String?
  city         String?
  state        String?
  zipCode      String?
  email        String?
  birthDate    DateTime?
  contactTime  String?
  status       LeadStatus   @default(newLead)
  companyId    Int
  teamId       Int
  assignedToId Int
  type         TypeCustomer @default(lead)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  company      Company      @relation(fields: [companyId], references: [id])
  team         Team         @relation(fields: [teamId], references: [id])
  assignedTo   User         @relation(fields: [assignedToId], references: [id])
  documents    Document[]
  notes        Note[]
  reminders    Reminder[]
  products     Product[]
}

// ─── DOCUMENTO ADJUNTO ───────────────────────────────────────────────────────

model Document {
  id        Int      @id @default(autoincrement())
  leadId    Int
  name      String
  url       String
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

// ─── NOTA ────────────────────────────────────────────────────────────────────

model NoteAttachment {
  id        Int      @id @default(autoincrement())
  noteId    Int
  name      String
  url       String
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model Note {
  id          Int              @id @default(autoincrement())
  leadId      Int
  authorId    Int
  title       String
  content     String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  attachments NoteAttachment[]

  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])
}

// ─── REMINDER ────────────────────────────────────────────────────────────────────
model Reminder {
  id             Int       @id @default(autoincrement())
  leadId         Int
  scheduledAt    DateTime
  reason         String
  status         String    @default("PENDING")
  lastNotifiedAt DateTime?
  assignedToId   Int
  createdById    Int
  createdAt      DateTime  @default(now())

  lead       Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo User @relation("ReminderAssignedTo", fields: [assignedToId], references: [id], map: "fk_reminder_assigned_to")
  createdBy  User @relation("ReminderCreatedBy", fields: [createdById], references: [id], map: "fk_reminder_created_by")
}

// ─── ENUMS (agregar) ─────────────────────────────────────────────────────────

enum ProductType {
  ALERTA_ANUAL
  ALERTA_TRIMESTRAL
  REPARACION_CREDITO
  FORTALECIMIENTO_FINANCIERO
}

enum PaymentMethodType {
  TARJETA
  CUENTA
}

enum CardType {
  DEBITO
  CREDITO
}

// ─── PRODUCTO DEL LEAD ───────────────────────────────────────────────────────

enum ProductStatus {
  ACTIVE
  SUSPENDED
}

model Product {
  id        Int           @id @default(autoincrement())
  leadId    Int
  product   ProductType
  createdAt DateTime      @default(now())
  status    ProductStatus @default(ACTIVE)

  lead          Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod?
  paymentPlan   PaymentPlan?
}

enum AccountType {
  AHORROS
  CHEQUES
}

model PaymentMethod {
  id            Int               @id @default(autoincrement())
  productId     Int               @unique
  type          PaymentMethodType
  cardType      CardType?
  lastFour      String?
  holderName    String?
  bank          String?
  accountNumber String?
  accountHolder String?
  accountBank   String?
  routingNumber String?
  accountType   AccountType?

  leadProduct Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PaymentPlan {
  id           Int           @id @default(autoincrement())
  productId    Int           @unique
  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  installments Installment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Installment {
  id            Int         @id @default(autoincrement())
  paymentPlanId Int
  paymentPlan   PaymentPlan @relation(fields: [paymentPlanId], references: [id], onDelete: Cascade)
  number        Int
  date          DateTime
  amount        Decimal     @db.Decimal(10, 2)
}
